{
  "entities": {
    "MenuItem": {
      "title": "MenuItem",
      "description": "A menu item in the restaurant",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "image_url": { "type": "string", "format": "uri" },
        "is_active": { "type": "boolean", "description": "Soft delete flag" },
        "is_available": { "type": "boolean", "description": "Sold out flag" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "price", "is_active", "is_available"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "avatar": { "type": "string", "format": "uri" },
        "memberSince": { "type": "string" },
        "totalOrders": { "type": "number" },
        "loyaltyPoints": { "type": "number" }
      },
      "required": ["role", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "string", "description": "JSON stringified array of CartItems" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "ready", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "date": { "type": "string" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "An audit log for admin actions",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "item": { "type": "string" },
        "user": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["action", "item", "user", "createdAt"]
    }
  },
  "firestore": {
    "/menuItems/{itemId}": {
      "schema": { "$ref": "#/entities/MenuItem" },
      "description": "Menu items collection"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users collection"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Orders collection"
    },
    "/auditLogs/{logId}": {
      "schema": { "$ref": "#/entities/AuditLog" },
      "description": "Audit logs collection"
    }
  }
}
